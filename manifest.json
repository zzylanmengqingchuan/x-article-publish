{
  "manifest_version": 3,
  "name": "X Article Publish Helper",
  "version": "1.0.0",
  "description": "Paste Markdown into X Articles and auto-upload linked images through native editor flow.",
  "permissions": ["storage", "tabs", "activeTab", "clipboardRead", "clipboardWrite"],
  "host_permissions": ["*://x.com/*", "<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["*://x.com/*"],
      "js": [
        "lib/markdown-it.min.js",
        "lib/highlight.min.js",
        "content/markdown-converter.js",
        "content/platforms/x.js",
        "content/main.js"
      ],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  }
}
